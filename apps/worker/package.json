{
  "name": "@makuhari/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --platform node --target node22 --sourcemap --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@makuhari/prompt-builder": "workspace:*",
    "@makuhari/shared-types": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "hono": "^4.12.10",
    "zod": "^4.3.6"
  }
}
